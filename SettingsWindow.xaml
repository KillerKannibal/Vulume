<Window x:Class="VolumeHUD.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="Vulume Settings" Height="350" Width="400"
        Background="#1e1e1e" Foreground="White"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="VULUME CONFIGURATION" FontSize="18" FontWeight="Bold" 
                       Foreground="#00FF41" Margin="0,0,0,20"/>

            <TextBlock Text="HUD Color" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <xctk:ColorPicker x:Name="HUDColorPicker" 
                              UsingAlphaChannel="False" 
                              SelectedColorChanged="HUDColorPicker_SelectedColorChanged"
                              Height="30" Background="#333333" Foreground="White"
                              BorderBrush="#00FF41"/>
            
            <TextBlock Text="Hex Code" Margin="0,10,0,5" FontSize="10" Opacity="0.6"/>
            <TextBox x:Name="ColorInput" IsReadOnly="True" Background="#252525" 
                     Foreground="#00FF41" BorderThickness="1" BorderBrush="#444" Padding="5"/>

            <TextBlock Text="Vertical Position Offset" Margin="0,15,0,5" FontWeight="SemiBold"/>
            <Slider x:Name="OffsetSlider" Minimum="0" Maximum="500" Value="100"
                    ValueChanged="OffsetSlider_ValueChanged"/>
    
            <Button Content="Apply &amp; Close" Click="SaveButton_Click" Margin="0,30,0,0" 
                    Background="#00FF41" Foreground="Black" FontWeight="Bold" Height="35"/>
        </StackPanel>
    </Grid>
</Window>