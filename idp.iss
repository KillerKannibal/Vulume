ection and click \u003cspan class=\"pl-cce\"\u003e\u0026#39;\u0026#39;\u003c/span\u003eRetry\u003cspan class=\"pl-cce\"\u003e\u0026#39;\u0026#39;\u003c/span\u003e to try downloading the files again, or click \u003cspan class=\"pl-cce\"\u003e\u0026#39;\u0026#39;\u003c/span\u003eCancel\u003cspan class=\"pl-cce\"\u003e\u0026#39;\u0026#39;\u003c/span\u003e to terminate setup.\u003cspan class=\"pl-pds\"\u003e\u0026#39;\u003c/span\u003e\u003c/span\u003e, ExpandConstant(\u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026#39;\u003c/span\u003e{cm:IDP_RetryCancel}\u003cspan class=\"pl-pds\"\u003e\u0026#39;\u003c/span\u003e\u003c/span\u003e));\u003c/span\u003e","\u003cspan class=\"pl-s1\"\u003e\u003cspan class=\"pl-k\"\u003eend\u003c/span\u003e;\u003c/span\u003e","\u003cspan class=\"pl-s1\"\u003e\u003c/span\u003e","\u003cspan class=\"pl-s1\"\u003e\u003cspan class=\"pl-k\"\u003eprocedure\u003c/span\u003e \u003cspan class=\"pl-en\"\u003eidpDownloadAfter\u003c/span\u003e(PageAfterId: Integer);\u003c/span\u003e","\u003cspan class=\"pl-s1\"\u003e\u003cspan class=\"pl-k\"\u003ebegin\u003c/span\u003e\u003c/span\u003e","\u003cspan class=\"pl-s1\"\u003e    idpCreateDownloadForm(PageAfterId);\u003c/span\u003e","\u003cspan class=\"pl-s1\"\u003e    idpConnectControls;\u003c/span\u003e","\u003cspan class=\"pl-s1\"\u003e    idpInitMessages;\u003c/span\u003e","\u003cspan class=\"pl-s1\"\u003e\u003cspan class=\"pl-k\"\u003eend\u003c/span\u003e;\u003c/span\u003e","\u003cspan class=\"pl-s1\"\u003e\u003c/span\u003e","\u003cspan class=\"pl-s1\"\u003e#include \u0026lt;idplang\\default.iss\u0026gt;\u003c/span\u003e"]}},"title":"inno-download-plugin/idp.iss at master · PeterDaveHello/inno-download-plugin","appPayload":{},"meta":{"title":"inno-download-plugin/idp.iss at master · PeterDaveHello/inno-download-plugin"}}</script>
