<Window x:Class="VolumeHUD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VolumeHUD" Height="60" Width="300"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="Manual">
    <Border x:Name="MainBorder" CornerRadius="15" Background="#222222" BorderBrush="#00FF41" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="#00FF41" BlurRadius="15" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" Margin="15,0">
            <Grid Margin="0,0,15,0">
                <TextBlock x:Name="VolLabel" Text="VOL" VerticalAlignment="Center" 
                   Foreground="#00FF41" FontWeight="Bold" Visibility="Visible"/>
                <TextBlock x:Name="MuteLabel" Text="✕ MUTE" VerticalAlignment="Center" 
                   Foreground="#FF4444" FontWeight="Bold" Visibility="Collapsed"/>
            </Grid>
    
                <ProgressBar x:Name="VolBar" Width="200" Height="10" 
                    Foreground="#00FF41" Background="#333333" 
                    BorderThickness="0" Value="50"/>
        </StackPanel>
    </Border>
</Window>